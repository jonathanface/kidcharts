{
  "family": "kidcharts-task",
  "containerDefinitions": [
    {
      "name": "kidcharts",
      "image": "691494729242.dkr.ecr.us-east-1.amazonaws.com/kidcharts:latest",
      "cpu": 0,
      "portMappings": [
        {
          "name": "kidcharts-80-tcp",
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/kidcharts-task",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "taskRoleArn": "arn:aws:iam::691494729242:role/ecs-personalsite",
  "executionRoleArn": "arn:aws:iam::691494729242:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}
